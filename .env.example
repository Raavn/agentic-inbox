# Prisma / PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/agentic_inbox?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Seed admin password (bcrypt-hashed at runtime during seed)
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# Aimeko token (used by AI agents to authenticate against /api/ai/* routes)
AIMEKO_TOKEN="aim_..."

# App URL (used by Pake desktop build and invite link generation)
APP_URL="https://your-domain.com"
