# Prisma / PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/agentic_inbox?schema=public"

# NextAuth
# Must match the AUTH_SECRET used by os.aimeko.com / acc.aimeko.com for cookie SSO
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (shared SSO provider)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Set to .aimeko.com in production so the session cookie is shared with
# os.aimeko.com / acc.aimeko.com
AUTH_COOKIE_DOMAIN=""

# Seed admin password (bcrypt-hashed at runtime during seed)
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# Aimeko token (used by AI agents to authenticate against /api/ai/* routes)
AIMEKO_TOKEN="aim_..."

# App URL (used by Pake desktop build and invite link generation)
APP_URL="https://your-domain.com"
